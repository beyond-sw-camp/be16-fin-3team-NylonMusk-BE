              "raw": "{{mkxPlatformUrl}}/api/delisting/violations/{{violationId}}/resolve?resolvedBy={{stockId}}&description=위반사항 해결 완료",
              "host": ["{{mkxPlatformUrl}}"],
              "path": ["api", "delisting", "violations", "{{violationId}}", "resolve"],
              "query": [
                {
                  "key": "resolvedBy",
